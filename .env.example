# AI 求职助手 - 配置文件
# 复制此文件为 .env 并填入实际值

# 飞书应用凭证
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here

# DeepSeek API
DEEPSEEK_API_KEY=sk-your_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# 求职偏好
JOB_KEYWORDS=AI视频,视频编解码,Python AI
JOB_CITY=深圳
JOB_SALARY_MIN=15000
JOB_SALARY_MAX=20000
JOB_WELFARE=双休,五险一金

# 投递设置
MATCH_THRESHOLD=70
MAX_DAILY_APPLY=50
GREET_INTERVAL_MIN=30
GREET_INTERVAL_MAX=120

# 飞书通知用户 Open ID（可选）
FEISHU_NOTIFY_OPEN_ID=
